/* app.wxss - 全局样式，所有页面共用 */

/* ── 颜色变量（方便统一修改主题色）─────────────────────────────────────── */
page {
  --color-primary: #4f46e5;       /* 主色：靛蓝紫 */
  --color-primary-light: #ede9fe; /* 主色浅版，用于背景 */
  --color-success: #10b981;       /* 绿色，成功状态 */
  --color-warning: #f59e0b;       /* 橙色，警告 */
  --color-text-main: #1f2937;     /* 主文字色 */
  --color-text-sub: #6b7280;      /* 副文字色 */
  --color-border: #e5e7eb;        /* 边框色 */
  --color-bg: #f5f7fa;            /* 页面背景 */
  --color-white: #ffffff;

  background-color: var(--color-bg);
  color: var(--color-text-main);
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* ── 通用卡片样式 ─────────────────────────────────────────────────────── */
.card {
  background: var(--color-white);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* ── 通用按钮样式 ─────────────────────────────────────────────────────── */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  color: var(--color-white);
  border-radius: 48rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  width: 100%;
}

.btn-primary[disabled] {
  background: #c4c4c4;
}

/* ── 输入框通用样式 ───────────────────────────────────────────────────── */
.input-box {
  width: 100%;
  background: #f9fafb;
  border: 2rpx solid var(--color-border);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--color-text-main);
  box-sizing: border-box;
}

.input-box:focus {
  border-color: var(--color-primary);
}

/* ── 标签样式 ─────────────────────────────────────────────────────────── */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: var(--color-primary-light);
  color: var(--color-primary);
}

/* ── 结果文本区域 ─────────────────────────────────────────────────────── */
.result-text {
  font-size: 28rpx;
  color: var(--color-text-main);
  line-height: 1.8;
  white-space: pre-wrap; /* 保留换行，正确显示 AI 输出的格式 */
}

/* ── 空状态提示 ───────────────────────────────────────────────────────── */
.empty-tip {
  text-align: center;
  color: var(--color-text-sub);
  font-size: 26rpx;
  padding: 60rpx 0;
}

/* ── 加载中提示 ───────────────────────────────────────────────────────── */
.loading-tip {
  text-align: center;
  color: var(--color-primary);
  font-size: 26rpx;
  padding: 40rpx 0;
}
