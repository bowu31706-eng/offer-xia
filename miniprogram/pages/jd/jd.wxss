/* jd.wxss - JD 备考分析页样式 */

.container {
  padding: 32rpx;
  padding-bottom: 60rpx;
}

/* 输入区域标签 */
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 16rpx;
}

.section-hint {
  font-size: 24rpx;
  color: var(--color-text-sub);
  margin-bottom: 16rpx;
}

/* JD 文本域 */
.jd-textarea {
  min-height: 240rpx;
  line-height: 1.7;
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-sub);
  margin-top: 8rpx;
}

/* 开始分析按钮 */
.btn-primary {
  margin-bottom: 40rpx;
}

/* 结果区域 */
.result-section {
  margin-top: 8rpx;
}

/* 步骤进度条 */
.progress-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  padding: 0 16rpx;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-sub);
}

.progress-step .dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--color-border);
  transition: background 0.3s;
}

.progress-step.active .dot {
  background: var(--color-primary);
  box-shadow: 0 0 0 6rpx var(--color-primary-light);
}

.progress-step.active {
  color: var(--color-primary);
  font-weight: 600;
}

.progress-step.done .dot {
  background: var(--color-success);
}

.progress-step.done {
  color: var(--color-success);
}

.progress-line {
  flex: 1;
  height: 2rpx;
  background: var(--color-border);
  margin: 0 12rpx;
  margin-bottom: 28rpx; /* 对齐 dot */
}

/* 结果卡片 */
.result-card {
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-main);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--color-border);
}

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-outline {
  flex: 1;
  height: 88rpx;
  background: transparent;
  color: var(--color-primary);
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-primary);
}
