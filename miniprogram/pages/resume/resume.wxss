/* resume.wxss - 简历优化页样式 */

.container {
  padding: 32rpx;
  padding-bottom: 60rpx;
}

/* 顶部提示条 */
.tip-banner {
  display: flex;
  align-items: flex-start;
  background: var(--color-primary-light);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.tip-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: var(--color-primary);
  line-height: 1.6;
}

/* 输入区域标签 */
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 16rpx;
}

.optional {
  font-size: 24rpx;
  color: var(--color-text-sub);
  font-weight: 400;
}

.section-hint {
  font-size: 24rpx;
  color: var(--color-text-sub);
  margin-bottom: 16rpx;
}

/* 简历文本域 */
.resume-textarea {
  min-height: 320rpx;
  line-height: 1.7;
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-sub);
  margin-top: 8rpx;
}

/* 开始按钮 */
.btn-primary {
  margin-bottom: 40rpx;
}

/* 结果卡片 */
.result-card {
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-main);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--color-border);
}

/* 加载状态 */
.loading-block {
  padding: 20rpx 0;
  text-align: center;
}

.loading-hint {
  font-size: 22rpx;
  color: var(--color-text-sub);
  margin-top: 8rpx;
}

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 24rpx;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-outline {
  flex: 1;
  height: 88rpx;
  background: transparent;
  color: var(--color-primary);
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-primary);
}
